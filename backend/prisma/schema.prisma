// ============================================
// OrdenaTEC — Prisma Schema
// Defines the data model for the e-commerce
// PC configurator platform.
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Enums ----

/// Roles de usuario en la plataforma
enum Rol {
  CLIENTE
  ADMIN
}

/// Tipos de componentes de PC
enum TipoComponente {
  CPU
  MOTHERBOARD
  RAM
  GPU
  ALMACENAMIENTO
  PSU
  GABINETE
  MONITOR
  TECLADO
  MOUSE
  AUDIFONOS
  SILLA
  MOUSEPAD
  WEBCAM
  MICROFONO
  BOCINAS
}

/// Tipo de vivienda registrada para la dirección de envío
enum TipoVivienda {
  CASA
  DEPARTAMENTO
  OFICINA
  OTRO
}

/// Estados posibles de un pedido
enum EstadoPedido {
  PENDIENTE
  PAGADO
  ENVIADO
  ENTREGADO
  CANCELADO
}

/// Estados posibles de un pago
enum EstadoPago {
  PENDIENTE
  COMPLETADO
  FALLIDO
  REEMBOLSADO
}

// ---- Models ----

/// Usuario registrado en la plataforma
model Usuario {
  id              String          @id @default(uuid())
  email           String          @unique
  nombre          String
  password        String          // Hash bcrypt
  rol             Rol             @default(CLIENTE)
  configuraciones Configuracion[]
  pedidos         Pedido[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("usuarios")
}

/// Componente de PC disponible en el catálogo
model Componente {
  id         String                     @id @default(uuid())
  sku        String                     @unique
  nombre     String
  tipo       TipoComponente
  precio     Float
  stock      Int                        @default(0)
  atributos  Json                       // Atributos dinámicos según tipo
  imagenUrl  String?
  activo     Boolean                    @default(true)
  configuraciones ConfiguracionComponente[]
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt

  @@index([tipo])
  @@index([activo])
  @@map("componentes")
}

/// Configuración de PC armada por el usuario
model Configuracion {
  id              String                     @id @default(uuid())
  nombre          String?
  usuarioId       String?
  usuario         Usuario?                   @relation(fields: [usuarioId], references: [id])
  precioTotal     Float                      @default(0)
  consumoEstimado Float?                     // Watts estimados
  esPrearmada     Boolean                    @default(false)
  categoria       String?                    // "Gaming", "Workstation", "Budget", "Streaming"
  descripcion     String?                    // Marketing description
  imagenUrl       String?                    // Hero image for prebuilt card
  destacada       Boolean                    @default(false)
  componentes     ConfiguracionComponente[]
  pedidos         Pedido[]
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@map("configuraciones")
}

/// Tabla intermedia: relación muchos-a-muchos entre Configuracion y Componente
model ConfiguracionComponente {
  configuracionId String
  componenteId    String
  configuracion   Configuracion @relation(fields: [configuracionId], references: [id], onDelete: Cascade)
  componente      Componente    @relation(fields: [componenteId], references: [id], onDelete: Cascade)

  @@id([configuracionId, componenteId])
  @@map("configuracion_componentes")
}

/// Pedido realizado por un usuario
model Pedido {
  id                  String          @id @default(uuid())
  usuarioId           String
  usuario             Usuario         @relation(fields: [usuarioId], references: [id])
  configuracionId     String?
  configuracion       Configuracion?  @relation(fields: [configuracionId], references: [id])
  estado              EstadoPedido    @default(PENDIENTE)
  total               Float
  // ---- Dirección de envío desglosada ----
  // Nombre legacy (mantener para retrocompatibilidad con pedidos viejos).
  nombreDestinatario  String?
  // Nombre desglosado (preferido en pedidos nuevos).
  nombreDestinatarioPila    String?  // Nombre(s) de pila
  apellidoPaterno     String?
  apellidoMaterno     String?
  telefonoContacto    String?
  telefonoAlternativo String?
  calle               String?
  numeroExterior      String?
  numeroInterior      String?
  entreCalles         String?
  colonia             String?
  alcaldiaMunicipio   String?
  ciudad              String?
  estadoEnvio         String?         // nombre del estado/provincia (evita choque con "estado")
  codigoPostal        String?
  pais                String?
  tipoVivienda        TipoVivienda?
  referenciasEnvio    String?
  pagos               Pago[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@map("pedidos")
}

/// Registro de pago asociado a un pedido
model Pago {
  id        String     @id @default(uuid())
  pedidoId  String
  pedido    Pedido     @relation(fields: [pedidoId], references: [id])
  monto     Float
  metodo    String     // "tarjeta", "transferencia", "simulado"
  estado    EstadoPago @default(PENDIENTE)
  fecha     DateTime   @default(now())

  @@map("pagos")
}
